{
  "crons": [
    {
      "path": "/api/scrape",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/enrich",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/image_fetcher",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/maintenance",
      "schedule": "0 6 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
